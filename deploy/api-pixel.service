[Unit]
Description=API Pixel (CAPI only)
After=network.target

[Service]
User=api-pixel
WorkingDirectory=/opt/api-pixel
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/api-pixel/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
